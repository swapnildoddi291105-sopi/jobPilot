    "express": "^4.21.0",
    "express-rate-limit": "^8.5.2",
    "googleapis": "^144.0.0",
    "helmet": "^8.2.0",
    "mammoth": "^1.12.0",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "pdf-parse": "^1.1.1"
