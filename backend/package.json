{
  "name": "jobpilot-backend",
  "version": "1.0.0",
  "description": "Backend for AI Job Automation Platform — Supabase, Google Drive, Gemini, Apify",
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
