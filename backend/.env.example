# ============================================
# JobPilot — Backend Environment Variables
# ============================================

# ---- Required ----
PORT=5000
NODE_ENV=development

# Supabase (get these from Supabase dashboard -> Settings -> API)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_KEY=your-service-role-key-here

# Client origin for CORS (the frontend URL)
CLIENT_URL=http://localhost:5173

# Admin email for notifications
# ADMIN_EMAIL=admin@example.com

# ---- Optional (features degrade gracefully without them) ----

# Gemini AI (for resume parsing & optimization)
# GEMINI_API_KEY=your-gemini-api-key

# Resume files are stored in Supabase Storage (bucket: "resumes")
# No additional config needed — uses SUPABASE_URL + SUPABASE_SERVICE_KEY

# Apify (for job scraping)
# APIFY_API_TOKEN=your-apify-token
# APIFY_ACTOR_ID=beOaHHMFnzMr6nGNU

# n8n Admin Token (for admin route authentication)
# N8N_ADMIN_TOKEN=your-admin-token
