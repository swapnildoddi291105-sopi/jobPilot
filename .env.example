# ============================================
# JobPilot — Frontend Environment Variables
# ============================================

# Supabase project URL (from Supabase dashboard -> Settings -> API)
VITE_SUPABASE_URL=https://your-project-id.supabase.co

# Supabase anon/public key (safe for browser)
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Backend API URL (only needed if backend is on a different domain in production)
# Defaults to "/api" (proxied through Vite dev server)
# VITE_API_URL=https://your-backend.com
